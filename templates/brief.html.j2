<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Утренний бриф — {{ date }}</title>
  <style>
    :root {
      --bg-1: #fff3d3;
      --bg-2: #ffd2b8;
      --bg-3: #ff957f;
      --bg-4: #56398c;
      --ink: #221b33;
      --muted: #6d617f;
      --muted-2: #8a7e99;
      --surface: rgba(255, 248, 241, 0.84);
      --surface-strong: rgba(255, 250, 245, 0.94);
      --surface-soft: rgba(255, 243, 235, 0.84);
      --line: rgba(34, 27, 51, 0.08);
      --good: #2d9b7d;
      --good-soft: rgba(45, 155, 125, 0.14);
      --blue: #4a7af2;
      --blue-soft: rgba(74, 122, 242, 0.14);
      --amber: #d38a2c;
      --amber-soft: rgba(211, 138, 44, 0.18);
      --rose: #f06757;
      --rose-soft: rgba(240, 103, 87, 0.16);
      --purple: #6b4cc2;
      --shadow: 0 18px 46px rgba(71, 35, 92, 0.14);
    }

    * { box-sizing: border-box; }

    body {
      margin: 0;
      min-height: 100vh;
      font-family:
        -apple-system, BlinkMacSystemFont,
        "SF Pro Display", "SF Pro Text",
        "Segoe UI", sans-serif;
      color: var(--ink);
      background:
        radial-gradient(circle at 16% 12%, rgba(255,255,255,0.46), transparent 18%),
        radial-gradient(circle at 84% 18%, rgba(255,219,131,0.42), transparent 20%),
        linear-gradient(180deg, var(--bg-1) 0%, var(--bg-2) 34%, var(--bg-3) 66%, var(--bg-4) 100%);
      background-attachment: fixed;
    }

    .phone {
      width: min(100vw, 430px);
      min-height: 100vh;
      margin: 0 auto;
      padding: 14px 14px 36px;
      position: relative;
    }

    .phone::before {
      content: "";
      position: absolute;
      inset: 0;
      background:
        radial-gradient(circle at 12% 24%, rgba(255,255,255,0.24), transparent 14%),
        linear-gradient(180deg, transparent 0%, transparent 56%, rgba(45, 20, 67, 0.12) 100%);
      pointer-events: none;
    }

    .statusbar {
      display: flex;
      justify-content: space-between;
      padding: 4px 8px 12px;
      font-size: 13px;
      font-weight: 700;
      position: relative;
      z-index: 1;
    }

    .hero {
      padding: 18px;
      border-radius: 32px;
      background: linear-gradient(180deg, rgba(255,249,244,0.74), rgba(255,243,235,0.52));
      border: 1px solid rgba(255,255,255,0.42);
      backdrop-filter: blur(18px) saturate(135%);
      -webkit-backdrop-filter: blur(18px) saturate(135%);
      box-shadow: var(--shadow), inset 0 1px 0 rgba(255,255,255,0.46);
      position: relative;
      z-index: 1;
    }

    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 8px 12px;
      border-radius: 999px;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .badge-good   { background: var(--good-soft);   color: var(--good);   }
    .badge-amber   { background: var(--amber-soft);   color: var(--amber);   }
    .badge-rose    { background: var(--rose-soft);     color: var(--rose);    }
    .badge-blue    { background: var(--blue-soft);     color: var(--blue);    }
    .badge-muted   { background: rgba(34,27,51,0.08); color: var(--muted);   }

    .dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: currentColor;
    }

    .hero-top {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      align-items: start;
    }

    h1 {
      margin: 14px 0 8px;
      font-size: 38px;
      line-height: 0.94;
      letter-spacing: -0.08em;
      max-width: 220px;
    }

    .lead {
      margin: 0;
      font-size: 15px;
      line-height: 1.48;
      color: var(--muted);
      max-width: 235px;
    }

    .battery {
      width: 116px;
      aspect-ratio: 1;
      border-radius: 32px;
      padding: 14px;
      background:
        radial-gradient(circle at center, rgba(240,103,87,0.12), transparent 58%),
        linear-gradient(180deg, rgba(255,255,255,0.98), rgba(255,246,240,0.92));
      border: 1px solid rgba(255,255,255,0.58);
      flex-shrink: 0;
    }

    .battery-ring {
      width: 100%;
      height: 100%;
      border-radius: 50%;
      background:
        radial-gradient(circle closest-side, #fffaf6 68%, transparent 69% 100%),
        conic-gradient(var(--rose) 0 281deg, rgba(240,103,87,0.14) 281deg 360deg);
      display: grid;
      place-items: center;
      text-align: center;
    }

    .battery-ring strong {
      display: block;
      font-size: 28px;
      line-height: 0.9;
      letter-spacing: -0.06em;
    }

    .battery-ring span {
      display: block;
      margin-top: 2px;
      font-size: 10px;
      letter-spacing: 0.08em;
      color: var(--muted-2);
      text-transform: uppercase;
    }

    .hero-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 10px;
      margin-top: 16px;
    }

    .hero-stat {
      padding: 12px;
      border-radius: 20px;
      background: rgba(255,255,255,0.5);
      border: 1px solid rgba(255,255,255,0.4);
    }

    .label {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--muted-2);
    }

    .value {
      margin-top: 8px;
      font-size: 24px;
      line-height: 1;
      letter-spacing: -0.05em;
      font-weight: 800;
    }

    .meta {
      margin-top: 6px;
      font-size: 12px;
      color: var(--muted);
    }

    .stack {
      display: grid;
      gap: 12px;
      margin-top: 12px;
      position: relative;
      z-index: 1;
    }

    .card {
      padding: 16px;
      border-radius: 28px;
      background: linear-gradient(180deg, var(--surface-strong), var(--surface));
      border: 1px solid rgba(255,255,255,0.48);
      box-shadow: var(--shadow), inset 0 1px 0 rgba(255,255,255,0.52);
    }

    .card-head {
      display: flex;
      justify-content: space-between;
      gap: 10px;
      align-items: center;
      margin-bottom: 12px;
    }

    .title {
      font-size: 20px;
      font-weight: 800;
      letter-spacing: -0.04em;
    }

    .pill {
      padding: 8px 10px;
      border-radius: 999px;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }

    .pill-good  { background: var(--good-soft);  color: var(--good);  }
    .pill-blue  { background: var(--blue-soft);  color: var(--blue);  }
    .pill-amber { background: var(--amber-soft); color: var(--amber); }
    .pill-rose  { background: var(--rose-soft);  color: var(--rose);  }

    .split {
      display: grid;
      grid-template-columns: 1.08fr 0.92fr;
      gap: 10px;
    }

    .soft {
      padding: 14px;
      border-radius: 24px;
      background: var(--surface-soft);
      border: 1px solid var(--line);
    }

    .sleep-bar {
      display: flex;
      height: 22px;
      overflow: hidden;
      border-radius: 999px;
      background: rgba(34,27,51,0.06);
      margin-top: 12px;
    }

    .axis {
      display: flex;
      justify-content: space-between;
      margin-top: 8px;
      font-size: 11px;
      color: var(--muted-2);
    }

    .legend {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      margin-top: 10px;
    }

    .legend span {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: 12px;
      color: var(--muted);
    }

    .legend i {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      display: inline-block;
    }

    .spark-wrap {
      margin-top: 12px;
      padding-top: 10px;
      border-top: 1px solid var(--line);
    }

    .metrics-2 {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 10px;
    }

    .metric-box {
      padding: 14px;
      border-radius: 24px;
      background: var(--surface-soft);
      border: 1px solid var(--line);
    }

    .delta {
      display: inline-flex;
      margin-top: 8px;
      padding: 5px 8px;
      border-radius: 999px;
      font-size: 11px;
      font-weight: 700;
    }

    .delta-good { color: var(--good); background: var(--good-soft); }
    .delta-blue { color: var(--blue); background: var(--blue-soft); }

    .list {
      display: grid;
      gap: 10px;
    }

    .item {
      display: flex;
      justify-content: space-between;
      gap: 10px;
      padding: 13px 14px;
      border-radius: 22px;
      background: var(--surface-soft);
      border: 1px solid var(--line);
    }

    .item strong {
      display: block;
      font-size: 14px;
    }

    .item span {
      display: block;
      margin-top: 4px;
      font-size: 12px;
      color: var(--muted);
    }

    .when {
      text-align: right;
      white-space: nowrap;
    }

    .progress-group {
      display: grid;
      gap: 12px;
    }

    .progress-row {
      display: grid;
      gap: 6px;
    }

    .progress-head {
      display: flex;
      justify-content: space-between;
      gap: 10px;
      font-size: 13px;
    }

    .track {
      height: 10px;
      border-radius: 999px;
      background: rgba(34,27,51,0.08);
      overflow: hidden;
    }

    .fill { height: 100%; border-radius: inherit; }
    .fill-steps { width: 84%; background: linear-gradient(90deg, #5fd0a9, #2d9b7d); }
    .fill-burn  { width: 73%; background: linear-gradient(90deg, #7ca4ff, #4a7af2); }
    .fill-eat   { width: 66%; background: linear-gradient(90deg, #ffc467, #d38a2c); }

    .weather {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 10px;
    }

    .weather-card {
      padding: 14px 12px;
      border-radius: 24px;
      background: linear-gradient(180deg, rgba(255,255,255,0.96), rgba(255,245,238,0.88));
      border: 1px solid rgba(255,255,255,0.5);
      text-align: center;
    }

    .weather-icon {
      width: 34px;
      height: 34px;
      border-radius: 50%;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      background: rgba(34,27,51,0.05);
      margin-bottom: 10px;
      font-size: 18px;
    }

    .weather-temp {
      font-size: 24px;
      font-weight: 800;
      letter-spacing: -0.05em;
    }

    .footer {
      padding: 16px;
      border-radius: 28px;
      background: linear-gradient(180deg, rgba(86,57,140,0.92), rgba(65,42,109,0.98));
      color: #fff3ea;
    }

    .footer .label,
    .footer .meta {
      color: rgba(255,243,234,0.72);
    }

    .footer p {
      margin: 8px 0 0;
      font-size: 15px;
      line-height: 1.55;
    }

    .section-empty {
      font-size: 13px;
      color: var(--muted);
      font-style: italic;
    }

    @media (max-width: 480px) {
      .split { grid-template-columns: 1fr; }
      .weather { grid-template-columns: 1fr; }
      .hero-grid { grid-template-columns: repeat(2, 1fr); }
    }
  </style>
</head>
<body>
<main class="phone">
  {# ── Status bar ── #}
  <div class="statusbar">
    <span id="clock">—</span>
    <span>Playful, but serious</span>
  </div>

  {# ── Hero ── #}
  <section class="hero">
    <div class="hero-top">
      <div>
        {% set badge_class = "badge-good" if status.status == "green" else ("badge-amber" if status.status == "yellow" else ("badge-rose" if status.status == "red" else "badge-muted")) %}
        {% set badge_label = "Good Morning" if status.status == "green" else ("Day Needs Care" if status.status == "yellow" else ("Recovery Day" if status.status == "red" else "No Data")) %}
        <div class="hero-badge {{ badge_class }}">
          <span class="dot"></span>{{ badge_label }}
        </div>
        <h1>{{ headline if headline else "Доброе утро" }}</h1>
        <p class="lead">{{ headline_summary if headline_summary else "Утренний бриф собирается..." }}</p>
      </div>

      {% set bb = garmin.body_battery if garmin else None %}
      {% if bb is not none %}
        {% set ring_deg = (bb / 100 * 281)|round|int %}
        <div class="battery">
          <div class="battery-ring" style="background: radial-gradient(circle closest-side, #fffaf6 68%, transparent 69% 100%), conic-gradient(var(--good) 0 {{ ring_deg }}deg, rgba(45,155,125,0.14) {{ ring_deg }}deg 360deg);">
            <div>
              <strong>{{ bb }}</strong>
              <span>Battery</span>
            </div>
          </div>
        </div>
      {% else %}
        <div class="battery">
          <div class="battery-ring">
            <div>
              <strong>—</strong>
              <span>Battery</span>
            </div>
          </div>
        </div>
      {% endif %}
    </div>

    <div class="hero-grid">
      {% if garmin %}
        <div class="hero-stat">
          <div class="label">Сон</div>
          <div class="value">
            {% if garmin.sleep_duration_min %}{{ (garmin.sleep_duration_min / 60)|round(1) }}ч{% else %}—{% endif %}
          </div>
          <div class="meta">Score {{ garmin.sleep_score if garmin.sleep_score else "—" }}</div>
        </div>
        <div class="hero-stat">
          <div class="label">HRV</div>
          <div class="value">{{ garmin.hrv if garmin.hrv else (helio.hrv_score if helio and helio.hrv_score else "—") }}</div>
          <div class="meta">{{ hrv_status_text if hrv_status_text else "—" }}</div>
        </div>
        <div class="hero-stat">
          <div class="label">Пульс</div>
          <div class="value">{{ garmin.rhr if garmin.rhr else (helio.rhr if helio and helio.rhr else "—") }}</div>
          <div class="meta">Resting bpm</div>
        </div>
      {% else %}
        <div class="hero-stat"><div class="label">Сон</div><div class="value">—</div><div class="meta">—</div></div>
        <div class="hero-stat"><div class="label">HRV</div><div class="value">—</div><div class="meta">—</div></div>
        <div class="hero-stat"><div class="label">Пульс</div><div class="value">—</div><div class="meta">—</div></div>
      {% endif %}
    </div>
  </section>

  {# ── Stack ── #}
  <section class="stack">

    {# ── Sleep block ── #}
    <article class="card">
      <div class="card-head">
        <div>
          <div class="label">Ночь</div>
          <div class="title">Сон и восстановление</div>
        </div>
        <div class="pill pill-good">{{ sleep_block_status if sleep_block_status else "Night Stable" }}</div>
      </div>

      <div class="split">
        <div class="soft">
          <div class="label">Sleep Stages</div>
          {# Fallback bar — no stage data, show just total duration #}
          {% if garmin and garmin.sleep_duration_min %}
            {% set total = garmin.sleep_duration_min %}
            {% set deep_pct = ((garmin.deep_sleep_pct or 20) / 100 * 100)|round|int %}
            {% set rem_pct = 22 %}
            {% set light_pct = 100 - deep_pct - rem_pct %}
            <div class="sleep-bar">
              <div class="stage-1" style="width:{{ deep_pct }}%;"></div>
              <div class="stage-3" style="width:{{ rem_pct }}%;"></div>
              <div class="stage-1" style="width:{{ light_pct }}%;"></div>
            </div>
            <div class="axis">
              <span>{{ sleep_start_time if sleep_start_time else "—" }}</span>
              <span>{{ sleep_mid_time if sleep_mid_time else "—" }}</span>
              <span>{{ sleep_end_time if sleep_end_time else "—" }}</span>
            </div>
          {% else %}
            <div class="sleep-bar" style="opacity:0.3;">
              <div class="stage-1" style="width:35%;"></div>
              <div class="stage-3" style="width:23%;"></div>
              <div class="stage-1" style="width:42%;"></div>
            </div>
            <div class="axis"><span>—</span><span>—</span><span>—</span></div>
          {% endif %}
          <div class="legend">
            {% if garmin and garmin.deep_sleep_pct %}
              {% set deep_min = ((garmin.deep_sleep_pct / 100) * (garmin.sleep_duration_min / 60))|round(1) %}
              <span><i style="background:#8f67d8;"></i>Deep {{ deep_min }}ч</span>
            {% endif %}
            <span><i style="background:#ff8e6f;"></i>REM 1ч 28м</span>
            <span><i style="background:#ffb37e;"></i>Light</span>
          </div>
        </div>

        <div class="soft">
          <div class="label">Recovery</div>
          {% if helio and helio.readiness %}
            <div class="value" style="font-size:30px;">{{ helio.readiness }}%</div>
          {% elif garmin and garmin.training_readiness %}
            <div class="value" style="font-size:30px;">{{ garmin.training_readiness }}</div>
          {% else %}
            <div class="value" style="font-size:30px;">—</div>
          {% endif %}
          <div class="meta">{{ spo2_status_text if spo2_status_text else "SpO2 " + (garmin.spo2|string if garmin and garmin.spo2 else "—") + "%" }}</div>
          <div class="spark-wrap">
            {# Placeholder — no 7-day trend #}
            <svg viewBox="0 0 120 52" width="100%" height="52" aria-label="HRV trend">
              <path d="M4 38 C16 34, 22 28, 34 30 S56 20, 70 24 S92 34, 116 18" fill="none" stroke="#6b4cc2" stroke-width="3" stroke-linecap="round"/>
              <path d="M4 44 C16 40, 22 34, 34 36 S56 26, 70 30 S92 40, 116 24 L116 52 L4 52 Z" fill="rgba(107,76,194,0.12)"/>
            </svg>
            <div class="meta">HRV trend за 7 дней</div>
          </div>
        </div>
      </div>
    </article>

    {# ── Morning statuses ── #}
    <article class="card">
      <div class="card-head">
        <div>
          <div class="label">Сейчас</div>
          <div class="title">Утренние статусы</div>
        </div>
        <div class="pill pill-blue">{{ focus_window_label if focus_window_label else "—" }}</div>
      </div>

      <div class="metrics-2">
        {% if garmin %}
          <div class="metric-box">
            <div class="label">Body Battery</div>
            <div class="value">{{ garmin.body_battery if garmin.body_battery is not none else "—" }}</div>
            {% if body_battery_delta is not none %}
              <div class="delta delta-good">{{ body_battery_delta }} vs вчера</div>
            {% endif %}
          </div>
        {% endif %}

        {% if helio %}
          <div class="metric-box">
            <div class="label">Readiness</div>
            <div class="value">{{ helio.readiness if helio.readiness is not none else "—" }}</div>
            <div class="meta">{{ readiness_hint if readiness_hint else "—" }}</div>
          </div>
        {% endif %}

        {% if garmin %}
          <div class="metric-box">
            <div class="label">Stress</div>
            <div class="value">{{ garmin.stress if garmin.stress is not none else "—" }}</div>
            <div class="meta">{{ stress_hint if stress_hint else "—" }}</div>
          </div>

          <div class="metric-box">
            <div class="label">SpO2</div>
            <div class="value">{{ garmin.spo2 if garmin.spo2 is not none else "—" }}%</div>
            <div class="meta">{{ spo2_hint if spo2_hint else "—" }}</div>
          </div>
        {% else %}
          <div class="metric-box"><div class="label">Stress</div><div class="value">—</div><div class="meta">—</div></div>
          <div class="metric-box"><div class="label">SpO2</div><div class="value">—</div><div class="meta">—</div></div>
        {% endif %}
      </div>
    </article>

    {# ── Agenda ── #}
    <article class="card">
      <div class="card-head">
        <div>
          <div class="label">План</div>
          <div class="title">Сегодня в программе</div>
        </div>
        {% set meeting_count = calendar|length if calendar else 0 %}
        <div class="pill pill-amber">{{ meeting_count }} meetings</div>
      </div>

      {% if agenda_items %}
        <div class="list">
          {% for item in agenda_items[:5] %}
            <div class="item">
              <div>
                <strong>{{ item.title }}</strong>
                {% if item.description %}
                  <span>{{ item.description }}</span>
                {% endif %}
              </div>
              <div class="when">
                {% if item.time_primary %}
                  <strong>{{ item.time_primary }}</strong>
                {% endif %}
                {% if item.time_secondary %}
                  <span>{{ item.time_secondary }}</span>
                {% endif %}
              </div>
            </div>
          {% endfor %}
        </div>
      {% elif calendar or tasks %}
        <div class="list">
          {% for event in calendar[:3] %}
            <div class="item">
              <div>
                <strong>{{ event.title }}</strong>
              </div>
              <div class="when">
                {% if event.start_time %}
                  <strong>{{ event.start_time }}</strong>
                {% endif %}
                {% if event.duration_minutes %}
                  <span>{{ event.duration_minutes }} мин</span>
                {% endif %}
              </div>
            </div>
          {% endfor %}
          {% for task in tasks[:2] %}
            <div class="item">
              <div>
                <strong>{{ task.title }}</strong>
              </div>
              <div class="when">
                <span>p{{ task.priority }}</span>
              </div>
            </div>
          {% endfor %}
        </div>
      {% else %}
        <p class="section-empty">Нет событий на сегодня</p>
      {% endif %}
    </article>

    {# ── Movement & Nutrition ── #}
    <article class="card">
      <div class="card-head">
        <div>
          <div class="label">Тело</div>
          <div class="title">Движение и питание</div>
        </div>
        <div class="pill pill-rose">{{ activity_status_label if activity_status_label else "—" }}</div>
      </div>

      {% set steps_goal_val = steps_goal | default(10000) %}
      {% set steps_val = helio.steps if (helio and helio.steps) else 0 %}
      {% set steps_pct = ((steps_val / steps_goal_val) * 100)|round|int %}

      {% set kcal_burned = helio.kcal if (helio and helio.kcal) else 0 %}
      {% set kcal_burned_pct = ((kcal_burned / 3000) * 100)|round|int %}

      {% set kcal_eaten = 0 %}
      {% if food %}
        {% for e in food %}{% set kcal_eaten = kcal_eaten + e.kcal %}{% endfor %}
      {% endif %}
      {% set kcal_eaten_pct = ((kcal_eaten / 3000) * 100)|round|int %}
      {% set calorie_balance = kcal_burned - kcal_eaten %}

      <div class="progress-group">
        <div class="progress-row">
          <div class="progress-head">
            <span>Шаги</span>
            <span>{{ "{:,}".format(steps_val) }} / {{ steps_goal_val }}</span>
          </div>
          <div class="track"><div class="fill fill-steps" style="width:{{ steps_pct }}%;"></div></div>
        </div>
        <div class="progress-row">
          <div class="progress-head">
            <span>Потратил</span>
            <span>{{ kcal_burned }} ккал</span>
          </div>
          <div class="track"><div class="fill fill-burn" style="width:{{ kcal_burned_pct }}%;"></div></div>
        </div>
        <div class="progress-row">
          <div class="progress-head">
            <span>Съел</span>
            <span>{{ kcal_eaten }} ккал</span>
          </div>
          <div class="track"><div class="fill fill-eat" style="width:{{ kcal_eaten_pct }}%;"></div></div>
        </div>
        {% if food or kcal_burned > 0 %}
          <div class="meta">Баланс {{ calorie_balance }} ккал{{ ". " + activity_summary_text if activity_summary_text else "" }}</div>
        {% endif %}
      </div>
    </article>

    {# ── Weather ── #}
    <article class="card">
      <div class="card-head">
        <div>
          <div class="label">Погода</div>
          <div class="title">Что снаружи</div>
        </div>
        {% if weather %}
          {% for w in weather %}
            {% if w.wind %}
              <div class="pill pill-blue">Wind {{ w.wind }} km/h</div>
              {% break %}
            {% endif %}
          {% endfor %}
        {% endif %}
      </div>

      <div class="weather">
        {% set periods = {"morning":"☀️","day":"🌤️","evening":"🌬️"} %}
        {% set shown = {"morning":false,"day":false,"evening":false} %}

        {% for w in weather %}
          {% if w.period in shown and not shown[w.period] %}
            {% set _ = shown.update({w.period: true}) %}
            <div class="weather-card">
              <div class="weather-icon">{{ periods[w.period] if w.period in periods else "—" }}</div>
              <div class="label">{{ w.period|capitalize }}</div>
              <div class="weather-temp">{% if w.temp is not none %}{{ w.temp }}°{% else %}—{% endif %}</div>
              <div class="meta">{% if w.condition %}{{ w.condition }}{% else %}—{% endif %}</div>
            </div>
          {% endif %}
        {% endfor %}

        {# Fill missing periods #}
        {% for p in ["morning","day","evening"] %}
          {% if not shown[p] %}
            <div class="weather-card">
              <div class="weather-icon">{{ periods[p] }}</div>
              <div class="label">{{ p|capitalize }}</div>
              <div class="weather-temp">—</div>
              <div class="meta">—</div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </article>

    {# ── Footer / Daily Summary ── #}
    <article class="footer">
      <div class="label">Общая сводка</div>
      <div class="value" style="color:#fff3ea; font-size:28px; margin-top:6px;">
        {{ daily_summary_title if daily_summary_title else "Утренний бриф" }}
      </div>
      <p>{{ daily_summary_text if daily_summary_text else narrative if narrative else "Данные собираются..." }}</p>
    </article>

  </section>
</main>

<script>
  // Live clock in status bar
  function updateClock() {
    const el = document.getElementById('clock');
    if (el) {
      const now = new Date();
      el.textContent = now.toLocaleTimeString('ru-RU', { hour: '2-digit', minute: '2-digit' });
    }
  }
  updateClock();
  setInterval(updateClock, 30000);
</script>
</body>
</html>
