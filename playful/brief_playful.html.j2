{# ────────────────────────────────────────────────────────────────────────
   Morning Brief — Production Playful (v2, по спеке оператора 2026-06-27)
   ────────────────────────────────────────────────────────────────────────
   Изменения против дефолтного brief.html.j2:
   - Убран status bar (Блок 0)
   - Hero badge → синяя капсула с датой DD MMMM (1a)
   - Battery ring → цвет по body_battery: ≥90 good, 75-89 amber, <75 rose (1d)
   - Sleep pill Night Stable → пороги ≥90 good, 75-89 amber, <75 rose (2a)
   - Sleep stages bar → 4 сегмента (deep/rem/light/awake), stage-5 не используем (2b)
   - Recovery → SpO2 в правой части 2c
   - Stress за вчера (3b)
   - Блок 4/1 Meetings + Deep Work слот
   - Блок 4/2 Задачи Todoist
   - Блок 6c Сравнение с предыдущим днём
   ──────────────────────────────────────────────────────────────────────── #}
<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Morning Brief — {{ date_label }}</title>
  <style>
    :root {
      --bg-1: #fff3d3;
      --bg-2: #ffd2b8;
      --bg-3: #ff957f;
      --bg-4: #56398c;
      --ink: #221b33;
      --muted: #6d617f;
      --muted-2: #8a7e99;
      --surface: rgba(255, 248, 241, 0.84);
      --surface-strong: rgba(255, 250, 245, 0.94);
      --surface-soft: rgba(255, 243, 235, 0.84);
      --line: rgba(34, 27, 51, 0.08);
      --good: #2d9b7d;
      --good-soft: rgba(45, 155, 125, 0.14);
      --blue: #4a7af2;
      --blue-soft: rgba(74, 122, 242, 0.14);
      --amber: #d38a2c;
      --amber-soft: rgba(211, 138, 44, 0.18);
      --rose: #f06757;
      --rose-soft: rgba(240, 103, 87, 0.16);
      --purple: #6b4cc2;
      --shadow: 0 18px 46px rgba(71, 35, 92, 0.14);
    }

    * { box-sizing: border-box; }

    body {
      margin: 0;
      min-height: 100vh;
      font-family:
        -apple-system, BlinkMacSystemFont,
        "SF Pro Display", "SF Pro Text",
        "Segoe UI", sans-serif;
      color: var(--ink);
      background:
        radial-gradient(circle at 16% 12%, rgba(255,255,255,0.46), transparent 18%),
        radial-gradient(circle at 84% 18%, rgba(255,219,131,0.42), transparent 20%),
        linear-gradient(180deg, var(--bg-1) 0%, var(--bg-2) 34%, var(--bg-3) 66%, var(--bg-4) 100%);
      background-attachment: fixed;
    }

    .phone {
      width: min(100vw, 430px);
      min-height: 100vh;
      margin: 0 auto;
      padding: 14px 14px 36px;
      position: relative;
    }

    .phone::before {
      content: "";
      position: absolute;
      inset: 0;
      background:
        radial-gradient(circle at 12% 24%, rgba(255,255,255,0.24), transparent 14%),
        linear-gradient(180deg, transparent 0%, transparent 56%, rgba(45, 20, 67, 0.12) 100%);
      pointer-events: none;
    }

    .hero {
      padding: 18px;
      border-radius: 32px;
      background: linear-gradient(180deg, rgba(255,249,244,0.74), rgba(255,243,235,0.52));
      border: 1px solid rgba(255,255,255,0.42);
      backdrop-filter: blur(18px) saturate(135%);
      -webkit-backdrop-filter: blur(18px) saturate(135%);
      box-shadow: var(--shadow), inset 0 1px 0 rgba(255,255,255,0.46);
      position: relative;
      z-index: 1;
    }

    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 8px 12px;
      border-radius: 999px;
      background: var(--blue-soft);
      color: var(--blue);
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .hero-top {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      align-items: start;
    }

    h1 {
      margin: 14px 0 8px;
      font-size: 38px;
      line-height: 0.94;
      letter-spacing: -0.08em;
      max-width: 220px;
    }

    .lead {
      margin: 0;
      font-size: 15px;
      line-height: 1.48;
      color: var(--muted);
      max-width: 235px;
    }

    .battery {
      width: 116px;
      aspect-ratio: 1;
      border-radius: 32px;
      padding: 14px;
      background:
        radial-gradient(circle at center, rgba(240, 103, 87, 0.12), transparent 58%),
        linear-gradient(180deg, rgba(255,255,255,0.98), rgba(255,246,240,0.92));
      border: 1px solid rgba(255,255,255,0.58);
      flex-shrink: 0;
    }

    .battery-ring {
      width: 100%;
      height: 100%;
      border-radius: 50%;
      background:
        radial-gradient(circle closest-side, #fffaf6 68%, transparent 69% 100%),
        conic-gradient(var(--{{ battery_color }}) 0 {{ battery_deg }}deg, {{ battery_track }} {{ battery_deg }}deg 360deg);
      display: grid;
      place-items: center;
      text-align: center;
    }

    .battery-ring strong {
      display: block;
      font-size: 28px;
      line-height: 0.9;
      letter-spacing: -0.06em;
    }

    .battery-ring span {
      display: block;
      margin-top: 2px;
      font-size: 10px;
      letter-spacing: 0.08em;
      color: var(--muted-2);
      text-transform: uppercase;
    }

    .hero-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 10px;
      margin-top: 16px;
    }

    .hero-stat {
      padding: 12px 10px;
      border-radius: 20px;
      background: rgba(255,255,255,0.5);
      border: 1px solid rgba(255,255,255,0.4);
    }

    .label {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--muted-2);
    }

    .value {
      margin-top: 8px;
      font-size: 24px;
      line-height: 1;
      letter-spacing: -0.05em;
      font-weight: 800;
    }

    .meta {
      margin-top: 6px;
      font-size: 12px;
      color: var(--muted);
    }

    .stack {
      display: grid;
      gap: 12px;
      margin-top: 12px;
      position: relative;
      z-index: 1;
    }

    .card {
      padding: 16px;
      border-radius: 28px;
      background: linear-gradient(180deg, var(--surface-strong), var(--surface));
      border: 1px solid rgba(255,255,255,0.48);
      box-shadow: var(--shadow), inset 0 1px 0 rgba(255,255,255,0.52);
    }

    .card-head {
      display: flex;
      justify-content: space-between;
      gap: 10px;
      align-items: center;
      margin-bottom: 12px;
    }

    .title {
      font-size: 20px;
      font-weight: 800;
      letter-spacing: -0.04em;
    }

    .pill {
      padding: 8px 10px;
      border-radius: 999px;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }

    .pill-good { background: var(--good-soft); color: var(--good); }
    .pill-blue { background: var(--blue-soft); color: var(--blue); }
    .pill-amber { background: var(--amber-soft); color: var(--amber); }
    .pill-rose { background: var(--rose-soft); color: var(--rose); }

    .split {
      display: grid;
      grid-template-columns: 1.08fr 0.92fr;
      gap: 10px;
    }

    .soft {
      padding: 14px;
      border-radius: 24px;
      background: var(--surface-soft);
      border: 1px solid var(--line);
    }

    .sleep-bar {
      display: flex;
      height: 22px;
      overflow: hidden;
      border-radius: 999px;
      background: rgba(34, 27, 51, 0.06);
      margin-top: 12px;
    }

    /* Sleep stages — 4 segments (deep / rem / light / awake). stage-5 не используется. */
    .stage-deep  { background: #8f67d8; }
    .stage-rem   { background: #ff8e6f; }
    .stage-light { background: #ffb37e; }
    .stage-awake { background: rgba(34, 27, 51, 0.18); }

    .axis {
      display: flex;
      justify-content: space-between;
      margin-top: 8px;
      font-size: 11px;
      color: var(--muted-2);
    }

    .legend {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      margin-top: 10px;
    }

    .legend span {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: 12px;
      color: var(--muted);
    }

    .legend i {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      display: inline-block;
    }

    .spark-wrap {
      margin-top: 12px;
      padding-top: 10px;
      border-top: 1px solid var(--line);
    }

    .metrics-2 {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 10px;
    }

    .metric-box {
      padding: 14px;
      border-radius: 24px;
      background: var(--surface-soft);
      border: 1px solid var(--line);
    }

    .delta {
      display: inline-flex;
      margin-top: 8px;
      padding: 5px 8px;
      border-radius: 999px;
      font-size: 11px;
      font-weight: 700;
    }

    .delta-good { color: var(--good); background: var(--good-soft); }
    .delta-rose { color: var(--rose); background: var(--rose-soft); }

    .list {
      display: grid;
      gap: 10px;
    }

    .item {
      display: flex;
      justify-content: space-between;
      gap: 10px;
      padding: 13px 14px;
      border-radius: 22px;
      background: var(--surface-soft);
      border: 1px solid var(--line);
      align-items: center;
    }

    .item strong {
      display: block;
      font-size: 14px;
    }

    .item .item-sub {
      display: block;
      margin-top: 4px;
      font-size: 12px;
      color: var(--muted);
    }

    /* Deep Work slot — визуально отличается от встреч: левая цветная полоса */
    .item-deepwork {
      background: linear-gradient(90deg, rgba(107, 76, 194, 0.12), var(--surface-soft) 30%);
      border-left: 3px solid var(--purple);
    }

    .item-priority {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 28px;
      height: 28px;
      border-radius: 8px;
      font-size: 11px;
      font-weight: 800;
      flex-shrink: 0;
    }

    .p1 { background: var(--rose-soft); color: var(--rose); }
    .p2 { background: var(--amber-soft); color: var(--amber); }
    .p3 { background: var(--blue-soft); color: var(--blue); }
    .p4 { background: rgba(34, 27, 51, 0.06); color: var(--muted); }

    .when {
      text-align: right;
      white-space: nowrap;
    }

    .progress-group {
      display: grid;
      gap: 12px;
    }

    .progress-row {
      display: grid;
      gap: 6px;
    }

    .progress-head {
      display: flex;
      justify-content: space-between;
      gap: 10px;
      font-size: 13px;
    }

    .track {
      height: 10px;
      border-radius: 999px;
      background: rgba(34, 27, 51, 0.08);
      overflow: hidden;
    }

    .fill { height: 100%; border-radius: inherit; }
    .fill-steps { background: linear-gradient(90deg, #5fd0a9, #2d9b7d); }
    .fill-burn  { background: linear-gradient(90deg, #7ca4ff, #4a7af2); }
    .fill-eat   { background: linear-gradient(90deg, #ffc467, #d38a2c); }

    .weather {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 10px;
    }

    .weather-card {
      padding: 14px 12px;
      border-radius: 24px;
      background: linear-gradient(180deg, rgba(255,255,255,0.96), rgba(255,245,238,0.88));
      border: 1px solid rgba(255,255,255,0.5);
      text-align: center;
    }

    .weather-icon {
      width: 34px;
      height: 34px;
      border-radius: 50%;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      background: rgba(34, 27, 51, 0.05);
      margin-bottom: 10px;
      font-size: 18px;
    }

    .weather-temp {
      font-size: 24px;
      font-weight: 800;
      letter-spacing: -0.05em;
    }

    .weather-vs-yesterday {
      margin-top: 14px;
      padding: 12px 14px;
      border-radius: 18px;
      background: linear-gradient(180deg, rgba(107,76,194,0.08), rgba(74,122,242,0.06));
      border: 1px solid rgba(107,76,194,0.12);
      font-size: 13px;
      color: var(--ink);
      line-height: 1.55;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .weather-vs-yesterday::before {
      content: "vs";
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 28px;
      height: 28px;
      border-radius: 50%;
      background: var(--purple);
      color: #fff3ea;
      font-size: 10px;
      font-weight: 800;
      letter-spacing: 0.04em;
      flex-shrink: 0;
    }

    .footer {
      padding: 16px;
      border-radius: 28px;
      background: linear-gradient(180deg, rgba(86,57,140,0.92), rgba(65,42,109,0.98));
      color: #fff3ea;
    }

    .footer .label,
    .footer .meta {
      color: rgba(255,243,234,0.72);
    }

    .footer p {
      margin: 8px 0 0;
      font-size: 15px;
      line-height: 1.55;
    }

    .section-empty {
      font-size: 13px;
      color: var(--muted);
      font-style: italic;
      padding: 8px 4px;
    }

    @media (max-width: 360px) {
      .split { grid-template-columns: 1fr; }
      .weather { grid-template-columns: 1fr; }
      .hero-grid { grid-template-columns: repeat(2, 1fr); }
    }
  </style>
</head>
<body>
<main class="phone">

  {# ── 1. Hero (без status bar — Блок 0 убран) ── #}
  <section class="hero">
    <div class="hero-top">
      <div>
        {# 1a Синяя капсула с датой DD MMMM #}
        <div class="hero-badge">{{ date_label }}</div>

        <h1>{{ headline }}</h1>
        <p class="lead">{{ headline_summary }}</p>
      </div>

      {# 1d Battery ring — цвет по body_battery: ≥90 good, 75-89 amber, <75 rose #}
      <div class="battery">
        <div class="battery-ring">
          <div>
            <strong>{{ battery_value }}</strong>
            <span>Battery</span>
          </div>
        </div>
      </div>
    </div>

    {# 1e Hero-grid: Сон / HRV / Пульс #}
    <div class="hero-grid">
      <div class="hero-stat">
        <div class="label">Сон</div>
        <div class="value">{{ sleep_label }}</div>
        <div class="meta">Sleep score {{ sleep_score }}</div>
      </div>
      <div class="hero-stat">
        <div class="label">HRV</div>
        <div class="value">{{ hrv_value }}</div>
        <div class="meta">{{ hrv_status }}</div>
      </div>
      <div class="hero-stat">
        <div class="label">Пульс</div>
        <div class="value">{{ rhr_value }}</div>
        <div class="meta">Resting bpm</div>
      </div>
    </div>
  </section>

  <section class="stack">

    {# ── 2. Сон и восстановление ── #}
    <article class="card">
      <div class="card-head">
        <div>
          <div class="label">Ночь</div>
          <div class="title">Сон и восстановление</div>
        </div>
        <div class="pill {{ sleep_pill_class }}">{{ sleep_pill_text }}</div>
      </div>

      <div class="split">
        {# 2b Sleep stages — 4 сегмента #}
        <div class="soft">
          <div class="label">Sleep Stages</div>
          <div class="sleep-bar">
            <div class="stage-deep"  style="width:{{ sleep_deep_pct  }}%;"></div>
            <div class="stage-rem"   style="width:{{ sleep_rem_pct   }}%;"></div>
            <div class="stage-light" style="width:{{ sleep_light_pct }}%;"></div>
            <div class="stage-awake" style="width:{{ sleep_awake_pct }}%;"></div>
          </div>
          <div class="axis">
            <span>{{ sleep_start_label }}</span>
            <span>{{ sleep_mid_label }}</span>
            <span>{{ sleep_end_label }}</span>
          </div>
          <div class="legend">
            <span><i style="background:#8f67d8;"></i>Deep {{ sleep_deep_label }}</span>
            <span><i style="background:#ff8e6f;"></i>REM {{ sleep_rem_label }}</span>
            <span><i style="background:#ffb37e;"></i>Light {{ sleep_light_label }}</span>
            {% if sleep_awake_label %}
              <span><i style="background:rgba(34,27,51,0.18);"></i>Awake {{ sleep_awake_label }}</span>
            {% endif %}
          </div>
        </div>

        {# 2c SpO2 + HRV-trend (вместо Recovery) #}
        <div class="soft">
          <div class="label">SpO2</div>
          <div class="value" style="font-size:30px;">{{ spo2_value }}%</div>
          {% if spo2_source_label %}
            <div class="meta" style="font-size:9px; color:var(--muted-2);">{{ spo2_source_label }}</div>
          {% else %}
            <div class="meta">{{ spo2_meta }}</div>
          {% endif %}
          <div class="spark-wrap">
            <svg viewBox="0 0 120 52" width="100%" height="52" aria-label="HRV trend">
              <path d="{{ hrv_trend_path }}" fill="none" stroke="#6b4cc2" stroke-width="3" stroke-linecap="round"/>
              <path d="{{ hrv_trend_area }}" fill="rgba(107,76,194,0.12)"/>
            </svg>
            <div class="meta">HRV trend за 7 дней</div>
          </div>
        </div>
      </div>
    </article>

    {# ── 3. Утренние статусы ── #}
    <article class="card">
      <div class="card-head">
        <div>
          <div class="label">Сейчас</div>
          <div class="title">Утренние статусы</div>
        </div>
        <div class="pill pill-blue">{{ focus_window_label }}</div>
      </div>

      <div class="metrics-2">
        <div class="metric-box">
          <div class="label">Body Battery</div>
          <div class="value">{{ battery_value }}</div>
          {% if battery_source_label %}
            <div class="meta" style="font-size:10px; color:var(--muted-2);">{{ battery_source_label }}</div>
          {% endif %}
          {% if body_battery_delta is not none %}
            <div class="delta {{ body_battery_delta_class }}">{{ body_battery_delta_label }}</div>
          {% endif %}
        </div>

        <div class="metric-box">
          <div class="label">Readiness</div>
          <div class="value">{{ readiness_label }}</div>
          <div class="meta">{{ readiness_meta }}</div>
        </div>

        <div class="metric-box">
          <div class="label">Stress <span style="font-size:9px; color:var(--muted-2);">(вчера)</span></div>
          <div class="value">{{ stress_label }}</div>
          <div class="meta">{{ stress_meta }}</div>
        </div>

        <div class="metric-box">
          <div class="label">SpO2 <span style="font-size:9px; color:var(--muted-2);">(вчера)</span></div>
          <div class="value">{{ spo2_value_square }}%</div>
          <div class="meta">{{ spo2_meta_short }}</div>
        </div>
      </div>
    </article>

    {# ── 4/1. Сегодня в программе (meetings + deep work) ── #}
    <article class="card">
      <div class="card-head">
        <div>
          <div class="label">План</div>
          <div class="title">Сегодня в программе</div>
        </div>
        <div class="pill pill-amber">{{ meeting_count_label }}</div>
      </div>

      {% if agenda_items %}
        <div class="list">
          {% for item in agenda_items %}
            <div class="item {{ item.css_class }}">
              <div>
                <strong>{{ item.title }}</strong>
                {% if item.description %}
                  <span class="item-sub">{{ item.description }}</span>
                {% endif %}
              </div>
              <div class="when">
                {% if item.time_primary %}
                  <strong>{{ item.time_primary }}</strong>
                {% endif %}
                {% if item.time_secondary %}
                  <span class="meta">{{ item.time_secondary }}</span>
                {% endif %}
              </div>
            </div>
          {% endfor %}
        </div>
      {% else %}
        <p class="section-empty">Нет событий на сегодня — свободный день.</p>
      {% endif %}
    </article>

    {# ── 4/2. Задачи на сегодня (Todoist) ── #}
    {% if tasks %}
    <article class="card">
      <div class="card-head">
        <div>
          <div class="label">Задачи</div>
          <div class="title">На сегодня</div>
        </div>
        <div class="pill pill-blue">{{ tasks_count_label }}</div>
      </div>
      <div class="list">
        {% for task in tasks[:5] %}
          <div class="item">
            <div class="item-priority p{{ task.priority|default(4) }}">p{{ task.priority|default(4) }}</div>
            <div style="flex:1;">
              <strong>{{ task.title }}</strong>
            </div>
            <div class="when">
              {% if task.due_time %}
                <strong>{{ task.due_time }}</strong>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>
    </article>
    {% endif %}

    {# ── 5. Движение и питание ── #}
    <article class="card">
      <div class="card-head">
        <div>
          <div class="label">Тело</div>
          <div class="title">Движение и питание</div>
        </div>
        <div class="pill pill-rose">{{ activity_pill }}</div>
      </div>

      <div class="progress-group">
        <div class="progress-row">
          <div class="progress-head">
            <span>Шаги</span>
            <span>{{ steps_value }} / {{ steps_goal }}</span>
          </div>
          <div class="track"><div class="fill fill-steps" style="width:{{ steps_pct }}%;"></div></div>
        </div>
        <div class="progress-row">
          <div class="progress-head">
            <span>Потратил</span>
            <span>{{ kcal_burned }} ккал</span>
          </div>
          <div class="track"><div class="fill fill-burn" style="width:{{ kcal_burned_pct }}%;"></div></div>
        </div>
        <div class="progress-row">
          <div class="progress-head">
            <span>Съел</span>
            <span>{{ kcal_eaten }} ккал</span>
          </div>
          <div class="track"><div class="fill fill-eat" style="width:{{ kcal_eaten_pct }}%;"></div></div>
        </div>
        {% if balance_meta %}
          <div class="meta">{{ balance_meta }}</div>
        {% endif %}
      </div>
    </article>

    {# ── 6. Что снаружи (погода) ── #}
    <article class="card">
      <div class="card-head">
        <div>
          <div class="label">Погода</div>
          <div class="title">Что снаружи</div>
        </div>
        {% if wind_pill_label %}
          <div class="pill pill-blue">{{ wind_pill_label }}</div>
        {% endif %}
      </div>

      <div class="weather">
        {% for w in weather_periods %}
          <div class="weather-card">
            <div class="weather-icon">{{ w.icon }}</div>
            <div class="label">{{ w.label }}</div>
            <div class="weather-temp">{{ w.temp }}</div>
            <div class="meta">{{ w.condition }}</div>
          </div>
        {% endfor %}
      </div>

      {# 6c Сравнение с предыдущим днём #}
      {% if weather_vs_yesterday %}
        <div class="weather-vs-yesterday">{{ weather_vs_yesterday }}</div>
      {% endif %}
    </article>

    {# ── 7. Footer — Общая сводка ── #}
    <article class="footer">
      <div class="label">Общая сводка</div>
      <div class="value" style="color:#fff3ea; font-size:28px; margin-top:6px;">{{ footer_title }}</div>
      <p>{{ footer_text }}</p>
    </article>

  </section>
</main>
</body>
</html>